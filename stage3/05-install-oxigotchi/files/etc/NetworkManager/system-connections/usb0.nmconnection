[connection]
id=usb0
type=ethernet
interface-name=usb0
autoconnect=true
autoconnect-priority=100

[ethernet]

[ipv4]
# "shared" gives usb0 a static IP AND runs dnsmasq (DHCP + NAT), so a computer
# plugged into the USB data port automatically gets an address and can reach
# the Pi at 10.0.0.2 (SSH) / 10.0.0.2:8080 (web dashboard).
method=shared
address1=10.0.0.2/24

[ipv6]
method=ignore
